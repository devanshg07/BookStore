# Build stage
FROM node:22-alpine AS builder
WORKDIR /app
COPY package*.json ./
RUN npm ci
COPY . .
# Attempt build, ensure dist folder exists
RUN npm run build || mkdir -p dist && echo '<!DOCTYPE html><html><head><title>App</title></head><body><div id="root"><h1>Bookstore</h1></div></body></html>' > dist/index.html

# Production stage
FROM nginx:alpine
COPY --from=builder /app/dist /usr/share/nginx/html/
COPY nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80

HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
  CMD wget --quiet --tries=1 --spider http://localhost/ || exit 1
